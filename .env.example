NEXT_PUBLIC_PADDLE_PRICE_STARTER_ANNUAL=pri_xxx
NEXT_PUBLIC_PADDLE_PRICE_PRO_MONTHLY=pri_xxx
NEXT_PUBLIC_PADDLE_PRICE_PRO_ANNUAL=pri_xxx

# --- Search (Meilisearch Cloud) ---
