# --- Database (Supabase project "tenderlist", ref ubmhbtqmzrhjnzorbtky, eu-central-1) ---
# Get the password from Supabase dashboard → Settings → Database (reset if unknown).
# Pooled connection (pgbouncer, port 6543) — app runtime
DATABASE_URL=postgresql://postgres.ubmhbtqmzrhjnzorbtky:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Direct connection (port 5432) — drizzle migrations only
DIRECT_URL=postgresql://postgres.ubmhbtqmzrhjnzorbtky:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Billing (Paddle) ---
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_xxx
NEXT_PUBLIC_PADDLE_ENV=sandbox
PADDLE_API_KEY=xxx
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxx
